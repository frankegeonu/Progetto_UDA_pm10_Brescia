<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pm10brescia.HelloController"
            style="-fx-background-color: #0f1117;">

    <!-- TOP: barra strumenti -->
    <top>
        <VBox style="-fx-background-color: #181c26; -fx-border-color: #2a3045; -fx-border-width: 0 0 1 0;">

            <!-- Riga 1: titolo + pulsanti -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <padding><Insets topRightBottomLeft="12 18 8 18"/></padding>

                <Label text="Valori PM10 · Brescia"
                       style="-fx-font-size: 18; -fx-font-weight: bold;
                              -fx-text-fill: #4FC3F7; -fx-font-family: Consolas;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="📂 Carica CSV"
                        onAction="#onCaricaCsv"
                        style="-fx-background-color: #4FC3F7; -fx-text-fill: #0f1117;
                               -fx-font-weight: bold; -fx-padding: 6 14; -fx-background-radius: 4;"/>

                <Button text="🔬 Dati di Esempio"
                        onAction="#onDatiEsempio"
                        style="-fx-background-color: #1e2330; -fx-text-fill: #e8eaf0;
                               -fx-border-color: #2a3045; -fx-border-radius: 4;
                               -fx-padding: 6 14; -fx-background-radius: 4;"/>

                <ProgressIndicator fx:id="progressIndicator" maxWidth="22" maxHeight="22"/>
            </HBox>

            <!-- Riga 2: filtri -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding><Insets topRightBottomLeft="0 18 10 18"/></padding>

                <Label text="Aggregazione:" style="-fx-text-fill: #9ba3b8; -fx-font-size: 12;"/>
                <ComboBox fx:id="comboAggregazione" minWidth="145"/>

                <Label text="Periodo:" style="-fx-text-fill: #9ba3b8; -fx-font-size: 12;"/>
                <ComboBox fx:id="comboPeriodo" minWidth="140"/>

                <Button text="Applica"
                        onAction="#onApplicaFiltri"
                        style="-fx-background-color: #81C784; -fx-text-fill: #0f1117;
                               -fx-font-weight: bold; -fx-padding: 5 12; -fx-background-radius: 4;"/>

                <Separator orientation="VERTICAL"/>

                <Label text="━  Linea rossa = soglia UE 50 µg/m³"
                       style="-fx-text-fill: #EF5350; -fx-font-size: 11;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER: TabPane con grafico + heatmap -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #0f1117;">

            <!-- Tab 1: grafico a linee -->
            <Tab text="📈  Grafico a linee">
                <LineChart fx:id="lineChart"
                           title="Andamento PM10 · Sensori ARPA Brescia"
                           style="-fx-background-color: #181c26;">
                    <xAxis>
                        <CategoryAxis label="Data e ora" tickLabelRotation="-40"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="PM10 (µg/m³)" forceZeroInRange="false"/>
                    </yAxis>
                </LineChart>
            </Tab>

            <!-- Tab 2: mappa di calore -->
            <!-- heatMapContainer è il BorderPane nel quale il controller
                 monta il contenuto di HeatMapView -->
            <Tab text="🌡  Mappa di calore">
                <BorderPane fx:id="heatMapContainer"
                            style="-fx-background-color: #0f1117;"/>
            </Tab>

        </TabPane>
    </center>

    <!-- BOTTOM: barra di stato -->
    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: #181c26;
                     -fx-border-color: #2a3045; -fx-border-width: 1 0 0 0;">
            <padding><Insets topRightBottomLeft="6 18 6 18"/></padding>

            <Label fx:id="labelStatus"
                   text="Carica un file CSV o usa i dati di esempio"
                   style="-fx-text-fill: #9ba3b8; -fx-font-size: 11;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelStats"
                   text=""
                   style="-fx-text-fill: #4FC3F7; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
