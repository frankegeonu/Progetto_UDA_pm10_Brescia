<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pm10brescia.HelloController"
            style="-fx-background-color: #0f1117;">

    <top>
        <VBox style="-fx-background-color: #181c26; -fx-border-color: #2a3045; -fx-border-width: 0 0 1 0;">

            <!-- Riga 1: titolo -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 12 18 8 18;">

                <Label text="Valori PM10 - Brescia"
                       style="-fx-font-size: 18; -fx-font-weight: bold;
                              -fx-text-fill: #4FC3F7; -fx-font-family: Consolas;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <ProgressIndicator fx:id="progressIndicator" maxWidth="22" maxHeight="22"/>
            </HBox>

            <!-- Riga 2: filtri -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 0 18 10 18;">

                <Label text="Aggregazione:" style="-fx-text-fill: #9ba3b8; -fx-font-size: 12;"/>
                <ComboBox fx:id="comboAggregazione" minWidth="145"/>

                <Label text="Periodo:" style="-fx-text-fill: #9ba3b8; -fx-font-size: 12;"/>
                <ComboBox fx:id="comboPeriodo" minWidth="140"/>

                <Button text="Applica"
                        onAction="#onApplicaFiltri"
                        style="-fx-background-color: #81C784; -fx-text-fill: #0f1117;
                               -fx-font-weight: bold; -fx-padding: 5 12; -fx-background-radius: 4;"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Linea rossa = soglia UE 50 microg/m3"
                       style="-fx-text-fill: #EF5350; -fx-font-size: 11;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #0f1117;">
            <tabs>
                <Tab text="Grafico a linee" closable="false">
                    <content>
                        <LineChart fx:id="lineChart"
                                   title="Andamento PM10 - Sensori ARPA Brescia"
                                   style="-fx-background-color: #181c26;">
                            <xAxis>
                                <CategoryAxis label="Data e ora" tickLabelRotation="-40"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="PM10 (microg/m3)" forceZeroInRange="false"/>
                            </yAxis>
                        </LineChart>
                    </content>
                </Tab>

                <Tab text="Mappa di calore" closable="false">
                    <content>
                        <BorderPane fx:id="heatMapContainer"
                                    style="-fx-background-color: #0f1117;"/>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: #181c26;
                     -fx-border-color: #2a3045; -fx-border-width: 1 0 0 0;
                     -fx-padding: 6 18 6 18;">

            <Label fx:id="labelStatus"
                   text="Caricamento..."
                   style="-fx-text-fill: #9ba3b8; -fx-font-size: 11;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelStats"
                   text=""
                   style="-fx-text-fill: #4FC3F7; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
